[0.059, "o", "Show a time report for a specific date or date range.\r\n\r\nExamples:\r\n  gtt report              # today\r\n  gtt report today        # today\r\n  gtt report yesterday    # yesterday\r\n  gtt report 2026-06-20   # specific date\r\n  gtt report week         # current week (Mon‚Äìtoday)\r\n  gtt report 2026-06-01:2026-06-07  # date range\r\n\r\n"]
[0.000, "o", "Usage:\r\n  gtt report [date|range] [flags]\r\n\r\nFlags:\r\n  -h, --help   help for report\r\n"]
