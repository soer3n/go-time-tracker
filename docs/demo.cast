[0.076, "o", "A terminal-based time tracker that stores entries as Markdown files.\r\n\r\n"]
[0.001, "o", "Usage:\r\n  gtt [flags]\r\n  gtt [command]\r\n\r\nAvailable Commands:\r\n  completion  Generate the autocompletion script for the specified shell\r\n  help        Help about any command\r\n  report      Show a time report\r\n\r\nFlags:\r\n  -h, --help   help for gtt\r\n\r\nUse \"gtt [command] --help\" for more information about a command.\r\n"]
